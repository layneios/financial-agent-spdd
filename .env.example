# Provider posture:
#   Ollama is the supported canonical local path.
#   For faster options see Opencode Zen or Opencode Go in README.
LLM_PROVIDER=ollama

# Postgres connection. The host-side default points at localhost because
# ingest / eval scripts run outside Docker. Inside docker-compose, this is
# overridden to db:5432 by the compose env.
PG_DSN=postgresql+psycopg://app:app@localhost:5432/app

# Logging mode: 'json' for production-style JSON, 'text' for local dev.
LOG_FORMAT=text

# --- Ollama (local) -----------------------------------------------------
# The base URL for the Ollama daemon. Defaults to host loopback for
# host-side scripts. Set to http://host.docker.internal:11434 when the
# FastAPI app runs inside compose and Ollama runs on the host (Mac), or
# to http://ollama:11434 if you add an Ollama service to compose.
OLLAMA_BASE_URL=http://localhost:11434

# Synthesis / final-answer model. Set this to whatever `ollama list`
# shows for the large model you want for user-facing turns.
OLLAMA_CHAT_MODEL=gemma3:27b

# Ops model for tagger / safety classifier / judge. Use a small fast
# instruct model. The default is a sensible starting point; pull it once
# with `ollama pull qwen3.5:4b`.
OLLAMA_OPS_MODEL=qwen3.5:4b

# Embedding model + dimension. nomic-embed-text is 768-dim; the schema's
# pgvector column is parameterised on EMBEDDING_DIM. If you change the
# model, update the dim AND drop / re-create doc_embeddings (immutable).
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Optional: tracing providers (Task 5) -------------------------------
# LANGSMITH_API_KEY=
# PHOENIX_COLLECTOR_ENDPOINT=
